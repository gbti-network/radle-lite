msgstr "Instala Yoast SEO para habilitar {yoast_meta_title} y {yoast_meta_description}"

msgid "Install Rank Math to enable {rankmath_meta_title} and {rankmath_meta_description}"
msgstr "Instala Rank Math para habilitar {rankmath_meta_title} y {rankmath_meta_description}"

msgid "More SEO tokens become available automatically when an SEO plugin is active:"
msgstr "Más tokens de SEO se vuelven disponibles automáticamente cuando un plugin de SEO está activo:"

msgid "Enable or disable rate limit monitoring. When enabled, Radle will track API usage and warn you when approaching Reddit API limits."
msgstr "Activa o desactiva el monitoreo del límite de tasa. Cuando está activado, Radle rastreará el uso de la API y te avisará cuando te acerques a los límites de la API de Reddit."

msgid "Title template must contain at least one token (e.g., {post_title})"
msgstr "La plantilla del título debe contener al menos un token (por ejemplo, {post_title})"

msgid "Content template must contain at least one token (e.g., {post_excerpt})"
msgstr "La plantilla de contenido debe contener al menos un token (por ejemplo, {post_excerpt})"

