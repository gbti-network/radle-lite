msgstr "Yoast SEO를 설치하여 {yoast_meta_title} 및 {yoast_meta_description}을 활성화하십시오."

msgid "Install Rank Math to enable {rankmath_meta_title} and {rankmath_meta_description}"
msgstr "Rank Math를 설치하여 {rankmath_meta_title} 및 {rankmath_meta_description}를 활성화하십시오."

msgid "More SEO tokens become available automatically when an SEO plugin is active:"
msgstr "SEO 플러그인이 활성화되면 더 많은 SEO 토큰이 자동으로 사용 가능해집니다"

