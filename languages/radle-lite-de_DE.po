msgstr "Installieren Sie Yoast SEO, um {yoast_meta_title} und {yoast_meta_description} zu aktivieren"

msgid "Install Rank Math to enable {rankmath_meta_title} and {rankmath_meta_description}"
msgstr "Installieren Sie Rank Math, um {rankmath_meta_title} und {rankmath_meta_description} zu aktivieren"

msgid "More SEO tokens become available automatically when an SEO plugin is active:"
msgstr "Weitere SEO-Token werden automatisch verfügbar, wenn ein SEO-Plugin aktiv ist:"

msgid "Enable or disable rate limit monitoring. When enabled, Radle will track API usage and warn you when approaching Reddit API limits."
msgstr "Aktivieren oder deaktivieren Sie die Überwachung des Ratenlimits. Wenn aktiviert, verfolgt Radle die API-Nutzung und warnt Sie, wenn Sie sich den Reddit API-Limits nähern."

msgid "Title template must contain at least one token (e.g., {post_title})"
msgstr "Die Titelvorlage muss mindestens ein Token enthalten (z.B. {post_title})"

msgid "Content template must contain at least one token (e.g., {post_excerpt})"
msgstr "Die Inhaltsvorlage muss mindestens ein Token enthalten (z.B. {post_excerpt})"

