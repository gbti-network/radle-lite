msgstr "💡 Dica: Crie links em markdown do Reddit combinando tokens:"

msgid "← Use this if title has [brackets]"
msgstr "← Utilize isto se o título contiver [parênteses retos]"

msgid "Additional SEO tokens:"
msgstr "Tokens SEO adicionais:"

