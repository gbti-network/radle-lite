msgstr "Instale o Yoast SEO para ativar {yoast_meta_title} e {yoast_meta_description}"

msgid "Install Rank Math to enable {rankmath_meta_title} and {rankmath_meta_description}"
msgstr "Instale o Rank Math para ativar {rankmath_meta_title} e {rankmath_meta_description}"

msgid "More SEO tokens become available automatically when an SEO plugin is active:"
msgstr "Mais tokens de SEO tornam-se disponíveis automaticamente quando um plugin de SEO está ativo:"

msgid "Enable or disable rate limit monitoring. When enabled, Radle will track API usage and warn you when approaching Reddit API limits."
msgstr "Ative ou desative o monitoramento do limite de taxa. Quando ativado, o Radle irá acompanhar o uso da API e avisará quando estiver a aproximar-se dos limites da API do Reddit."

msgid "Title template must contain at least one token (e.g., {post_title})"
msgstr "O modelo de título deve conter pelo menos um token (por exemplo, {post_title})"

msgid "Content template must contain at least one token (e.g., {post_excerpt})"
msgstr "O modelo de conteúdo deve conter pelo menos um token (por exemplo, {post_excerpt})"

