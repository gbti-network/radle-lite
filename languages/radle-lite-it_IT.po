msgstr "💡 Suggerimento: Crei collegamenti markdown di Reddit combinando token:"

msgid "← Use this if title has [brackets]"
msgstr "Utilizzi questo se il titolo contiene [parentesi quadre]"

msgid "Additional SEO tokens:"
msgstr "Token SEO aggiuntivi:"

msgid "Install Yoast SEO to enable {yoast_meta_title} and {yoast_meta_description}"
msgstr "Installi Yoast SEO per abilitare {yoast_meta_title} e {yoast_meta_description}"

msgid "Install Rank Math to enable {rankmath_meta_title} and {rankmath_meta_description}"
msgstr "Installi Rank Math per abilitare {rankmath_meta_title} e {rankmath_meta_description}"

msgid "More SEO tokens become available automatically when an SEO plugin is active:"
msgstr "Più token SEO diventano disponibili automaticamente quando un plugin SEO è attivo:"

msgid "Enable or disable rate limit monitoring. When enabled, Radle will track API usage and warn you when approaching Reddit API limits."
msgstr "Abiliti o disabiliti il monitoraggio del limite di frequenza. Quando abilitato, Radle traccerà l'uso dell'API e la avviserà quando si avvicina ai limiti dell'API di Reddit."

msgid "Title template must contain at least one token (e.g., {post_title})"
msgstr "Il modello del titolo deve contenere almeno un token (ad esempio, {post_title})"

msgid "Content template must contain at least one token (e.g., {post_excerpt})"
msgstr "Il modello di contenuto deve contenere almeno un token (ad esempio, {post_excerpt})"

