msgstr "Installera Yoast SEO för att aktivera {yoast_meta_title} och {yoast_meta_description}"

msgid "Install Rank Math to enable {rankmath_meta_title} and {rankmath_meta_description}"
msgstr "Installera Rank Math för att aktivera {rankmath_meta_title} och {rankmath_meta_description}"

msgid "More SEO tokens become available automatically when an SEO plugin is active:"
msgstr "Fler SEO-tokens blir automatiskt tillgängliga när ett SEO-tillägg är aktivt:"

msgid "Enable or disable rate limit monitoring. When enabled, Radle will track API usage and warn you when approaching Reddit API limits."
msgstr "Aktivera eller inaktivera övervakning av hastighetsbegränsning. När den är aktiverad kommer Radle att spåra API-användning och varna dig när du närmar dig Reddit API-gränserna."

msgid "Title template must contain at least one token (e.g., {post_title})"
msgstr "Titelmallen måste innehålla minst en token (t.ex. {post_title})"

msgid "Content template must contain at least one token (e.g., {post_excerpt})"
msgstr "Innehållsmallen måste innehålla minst ett token (t.ex. {post_excerpt})"

